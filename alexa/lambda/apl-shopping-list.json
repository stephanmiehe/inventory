{
  "type": "APL",
  "version": "2024.1",
  "import": [
    { "name": "alexa-layouts", "version": "1.7.0" }
  ],
  "mainTemplate": {
    "parameters": ["payload"],
    "items": [
      {
        "type": "Container",
        "width": "100vw",
        "height": "100vh",
        "items": [
          {
            "type": "Text",
            "text": "🛒 Einkaufsliste — ${payload.subtitle}",
            "fontSize": "24dp",
            "fontWeight": "bold",
            "paddingLeft": "3vw",
            "paddingTop": "2vh",
            "paddingBottom": "1vh"
          },
          {
            "type": "Sequence",
            "width": "100vw",
            "height": "85vh",
            "paddingLeft": "3vw",
            "paddingRight": "3vw",
            "numbered": false,
            "data": "${payload.listItems}",
            "items": [
              {
                "type": "Text",
                "text": "${data.text}",
                "fontSize": "${data.isHeader ? '20dp' : '22dp'}",
                "fontWeight": "${data.isHeader ? 'bold' : 'normal'}",
                "color": "${data.color}",
                "opacity": "${data.opacity}",
                "paddingTop": "${data.isHeader ? '2vh' : '0.8vh'}",
                "paddingBottom": "0.8vh"
              }
            ]
          }
        ]
      }
    ]
  }
}
