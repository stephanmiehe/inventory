{
  "type": "APL",
  "version": "2024.1",
  "theme": "dark",
  "import": [
    { "name": "alexa-layouts", "version": "1.7.0" }
  ],
  "extensions": [
    {
      "name": "DataStore",
      "uri": "alexaext:datastore:10"
    }
  ],
  "settings": {
    "DataStore": {
      "dataBindings": [
        {
          "namespace": "SHOPPING_LIST",
          "key": "listData",
          "dataBindingName": "dynamicData",
          "dataType": "OBJECT"
        }
      ]
    }
  },
  "mainTemplate": {
    "parameters": ["dynamicData"],
    "items": [
      {
        "type": "Container",
        "width": "100vw",
        "height": "100vh",
        "padding": "8dp",
        "items": [
          {
            "type": "Container",
            "direction": "row",
            "alignItems": "center",
            "spacing": "6dp",
            "paddingBottom": "4dp",
            "items": [
              {
                "type": "Text",
                "text": "Einkaufsliste",
                "fontWeight": "bold",
                "fontSize": "16dp",
                "grow": 1
              },
              {
                "type": "Text",
                "text": "${dynamicData.total} Artikel",
                "fontSize": "13dp",
                "opacity": 0.7
              }
            ]
          },
          {
            "type": "ScrollView",
            "grow": 1,
            "shrink": 1,
            "item": {
              "type": "Container",
              "items": [
                { "when": "${dynamicData.lineCount > 0}", "type": "Text", "text": "${dynamicData.line0}", "fontSize": "13dp", "maxLines": 1, "paddingTop": "2dp" },
                { "when": "${dynamicData.lineCount > 1}", "type": "Text", "text": "${dynamicData.line1}", "fontSize": "13dp", "maxLines": 1, "paddingTop": "2dp" },
                { "when": "${dynamicData.lineCount > 2}", "type": "Text", "text": "${dynamicData.line2}", "fontSize": "13dp", "maxLines": 1, "paddingTop": "2dp" },
                { "when": "${dynamicData.lineCount > 3}", "type": "Text", "text": "${dynamicData.line3}", "fontSize": "13dp", "maxLines": 1, "paddingTop": "2dp" },
                { "when": "${dynamicData.lineCount > 4}", "type": "Text", "text": "${dynamicData.line4}", "fontSize": "13dp", "maxLines": 1, "paddingTop": "2dp" },
                { "when": "${dynamicData.lineCount > 5}", "type": "Text", "text": "${dynamicData.line5}", "fontSize": "13dp", "maxLines": 1, "paddingTop": "2dp" },
                { "when": "${dynamicData.lineCount > 6}", "type": "Text", "text": "${dynamicData.line6}", "fontSize": "13dp", "maxLines": 1, "paddingTop": "2dp" },
                { "when": "${dynamicData.lineCount > 7}", "type": "Text", "text": "${dynamicData.line7}", "fontSize": "13dp", "maxLines": 1, "paddingTop": "2dp" },
                { "when": "${dynamicData.lineCount > 8}", "type": "Text", "text": "${dynamicData.line8}", "fontSize": "13dp", "maxLines": 1, "paddingTop": "2dp" },
                { "when": "${dynamicData.lineCount > 9}", "type": "Text", "text": "${dynamicData.line9}", "fontSize": "13dp", "maxLines": 1, "paddingTop": "2dp" },
                { "when": "${dynamicData.lineCount > 10}", "type": "Text", "text": "${dynamicData.line10}", "fontSize": "13dp", "maxLines": 1, "paddingTop": "2dp" },
                { "when": "${dynamicData.lineCount > 11}", "type": "Text", "text": "${dynamicData.line11}", "fontSize": "13dp", "maxLines": 1, "paddingTop": "2dp" }
              ]
            }
          },
          {
            "when": "${dynamicData.moreCount > 0}",
            "type": "Text",
            "text": "+ ${dynamicData.moreCount} weitere",
            "fontSize": "12dp",
            "opacity": 0.5,
            "paddingTop": "3dp"
          }
        ]
      }
    ]
  }
}
