{
  "packageVersion": "1.0",
  "packageType": "APL_PACKAGE",
  "manifest": {
    "id": "shopping-list",
    "version": "1.0.0",
    "installStateChanges": "INFORM",
    "updateStateChanges": "INFORM",
    "presentationDefinitions": [
      {
        "url": "presentations/default.tpl"
      }
    ],
    "appliesTo": "${viewport.mode == 'HUB'}"
  },
  "publishingInformation": {
    "schemaVersion": "1.0",
    "locales": {
      "de-DE": [
        {
          "targetViewport": "WIDGET_M",
          "metadata": {
            "name": "Einkaufsliste",
            "description": "Zeigt die aktuelle Einkaufsliste",
            "keywords": ["einkaufsliste", "shopping", "inventar"],
            "iconUri": "https://inventory.weidt.de/icons/icon-192x192.png"
          }
        }
      ]
    }
  }
}
