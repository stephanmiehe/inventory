{
  "type": "APL",
  "version": "2024.1",
  "theme": "dark",
  "import": [
    { "name": "alexa-layouts", "version": "1.7.0" }
  ],
  "mainTemplate": {
    "parameters": ["dynamicData"],
    "item": {
      "type": "Container",
      "width": "100vw",
      "height": "100vh",
      "padding": "8dp",
      "items": [
        {
          "type": "Container",
          "direction": "row",
          "alignItems": "center",
          "spacing": "6dp",
          "paddingBottom": "6dp",
          "items": [
            {
              "type": "Text",
              "text": "🛒",
              "fontSize": "22dp"
            },
            {
              "type": "Text",
              "text": "Einkaufsliste",
              "style": "textStyleBody",
              "fontWeight": "bold",
              "fontSize": "18dp",
              "grow": 1
            },
            {
              "type": "Text",
              "text": "${dynamicData.total} Artikel",
              "fontSize": "14dp",
              "opacity": 0.7
            }
          ]
        },
        {
          "type": "Sequence",
          "grow": 1,
          "shrink": 1,
          "numbered": false,
          "data": "${dynamicData.items}",
          "items": [
            {
              "type": "Container",
              "direction": "row",
              "alignItems": "center",
              "paddingTop": "3dp",
              "paddingBottom": "3dp",
              "items": [
                {
                  "type": "Text",
                  "text": "${data.icon}",
                  "fontSize": "14dp",
                  "width": "20dp"
                },
                {
                  "type": "Text",
                  "text": "${data.qty > 1 ? data.qty + '× ' : ''}${data.name}",
                  "fontSize": "15dp",
                  "grow": 1,
                  "maxLines": 1,
                  "opacity": "${data.checked ? 0.4 : 1.0}"
                }
              ]
            }
          ]
        },
        {
          "when": "${dynamicData.moreCount > 0}",
          "type": "Text",
          "text": "+ ${dynamicData.moreCount} weitere",
          "fontSize": "13dp",
          "opacity": 0.5,
          "paddingTop": "4dp"
        }
      ]
    }
  },
  "extensions": [
    {
      "uri": "alexaext:datastore:10",
      "name": "DataStore"
    }
  ],
  "settings": {
    "DataStore": {
      "dataBindings": [
        {
          "namespace": "SHOPPING_LIST",
          "key": "listData",
          "dataBindingName": "dynamicData",
          "dataType": "OBJECT"
        }
      ]
    }
  }
}
