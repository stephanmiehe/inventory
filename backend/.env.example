PORT=3001
# Comma-separated list of allowed origins for CORS
# In production with nginx proxy, requests come from the same origin
ALLOWED_ORIGINS=http://localhost:3000
# MongoDB connection for Open Food Facts product data
MONGO_URI=mongodb://localhost:27017
MONGO_DBS=off,opf,opff
MONGO_COLLECTION=products
# Static password for external access (leave empty to disable auth)
AUTH_PASSWORD=
# Comma-separated local subnet prefixes (requests from these are auto-allowed)
# LOCAL_SUBNETS=192.168.,10.
# Number of trusted reverse proxy hops (Caddy + nginx = 2)
TRUST_PROXY=2
# Azure OpenAI for product image recognition (leave empty to disable)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview
